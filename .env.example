# Home Assistant container image.
HA_IMAGE=ghcr.io/home-assistant/home-assistant:stable

# Persistent config directory on Synology.
HA_CONFIG_PATH=/volume1/docker/homeassistant/config

# Backups created by scripts/backup.sh and scripts/update-homeassistant.sh.
BACKUP_DIR=/volume1/docker/homeassistant/backups
BACKUP_RETENTION_COUNT=10

# Timezone used by the container and scripts.
TZ=Europe/Berlin

# Optional local API check for scripts/healthcheck.sh.
HA_BASE_URL=http://127.0.0.1:8123
HA_LONG_LIVED_TOKEN=

# Optional Compose project name.
COMPOSE_PROJECT_NAME=homeassistant
